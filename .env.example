# Supabase (publishable/anon keys — safe to expose, RLS protects the data)
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_URL="https://your-project.supabase.co"

# Sentry — error monitoring (optional, only loaded in production builds)
# Get your DSN from https://sentry.io > Project > Settings > Client Keys (DSN)
# Leave empty in local development to disable Sentry.
VITE_SENTRY_DSN=""
